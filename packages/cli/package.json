{
  "name": "gh-vibe",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "gh CLI extension for vibe — create git worktrees from PRs and issues",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build --compile --minify --outfile ../../gh-vibe src/main.ts",
    "test": "bun test",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
